<%- include('partials/header') %>
<main class="form-page">
    <div class="form-container">
        <div class="form-header">
            <h1><%= title %></h1>
            <p>Update the information for: <strong><%= project.title %></strong></p>
        </div>

        <form action="/edit-project/<%= project.project_id %>" method="POST">
            <div class="form-group">
                <label for="title">Project Title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    value="<%= project.title %>"
                    maxlength="200"
                    required
                />
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    maxlength="1000"
                    required
                ><%= project.description %></textarea>
            </div>

            <div class="form-group">
                <label for="location">Location</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    value="<%= project.location %>"
                    maxlength="200"
                    required
                />
            </div>

            <div class="form-group">
                <label for="date">Project Date</label>
                <% 
                    // Format date to YYYY-MM-DD for the date input
                    let formattedDate = '';
                    if (project.date) {
                        const d = new Date(project.date);
                        formattedDate = d.toISOString().split('T')[0];
                    }
                %>
                <input
                    type="date"
                    id="date"
                    name="date"
                    value="<%= formattedDate %>"
                    required
                />
            </div>

            <div class="form-group">
                <label for="organizationId">Sponsoring Organization</label>
                <select
                    id="organizationId"
                    name="organizationId"
                    required
                >
                    <option value="">Select an organization</option>
                    <% organizations.forEach(org => { %>
                    <option value="<%= org.organization_id %>" <%= org.organization_id === project.organization_id ? 'selected' : '' %>>
                        <%= org.name %>
                    </option>
                    <% }); %>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn"><i data-lucide="save" class="icon-sm"></i> Update Service Project</button>
                <a href="/project/<%= project.project_id %>" class="cancel-link">Cancel and go back</a>
            </div>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
