<%- include('partials/header') %>

<main class="organizations-page">
    <h1><%= title %></h1>
    
    <p class="intro-text">Here are a few of our partner organizations:</p>
    
    <div class="organizations-container">
        <div class="organization-card">
            <div class="org-icon">
                <img src="images/brightfuture-logo.png" alt="BrightFuture Builders Logo">
            </div>
            <div class="org-content">
                <h2>BrightFuture Builders</h2>
                <p><a href="mailto:info@brightfuture.org">info@brightfuture.org</a></p>
            </div>
        </div>

        <div class="organization-card">
            <div class="org-icon">
                <img src="images/greenharvest-logo.png" alt="GreenHarvest Growers Logo">
            </div>
            <div class="org-content">
                <h2>GreenHarvest Growers</h2>
                <p><a href="mailto:contact@greenharvest.org">contact@greenharvest.org</a></p>
            </div>
        </div>

        <div class="organization-card">
            <div class="org-icon">
                <img src="images/unityserve-logo.png" alt="UnityServe Volunteers Logo">
            </div>
            <div class="org-content">
                <h2>UnityServe Volunteers</h2>
                <p><a href="mailto:hello@unityserve.org">hello@unityserve.org</a></p>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
