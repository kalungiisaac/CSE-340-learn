<%- include('partials/header') %>
<main class="form-page">
    <div class="form-container">
        <div class="form-header">
            <h1><%= title %></h1>
            <p>Update information for the <strong><%= category.name %></strong> category.</p>
        </div>

        <form action="/edit-category/<%= category.category_id %>" method="POST">
            <div class="form-group">
                <label for="name">Category Name</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    value="<%= category.name %>"
                    minlength="3"
                    maxlength="100"
                    required
                />
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    maxlength="500"
                    required
                ><%= category.description %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn"><i data-lucide="save" class="icon-sm"></i> Update Category</button>
                <a href="/category/<%= category.category_id %>" class="cancel-link">Cancel and go back</a>
            </div>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
