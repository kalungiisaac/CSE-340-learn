<%- include('partials/header') %>

<main class="organization-details-page">
    <nav class="breadcrumb">
        <a href="/organizations">Organizations</a>
        <i data-lucide="chevron-right" class="icon-sm"></i>
        <span><%= organizationDetails ? organizationDetails.name : 'Details' %></span>
    </nav>

    <div class="mb-6">
        <a href="/organizations" class="button button-outline">
            <i data-lucide="arrow-left" class="icon-sm"></i>
            Back to All Organizations
        </a>
    </div>

    <h1><%= title %></h1>

    <% if (!organizationDetails) { %>
        <p>Organization not found.</p>
    <% } else { %>
        <section class="organization-summary">
            <h2><%= organizationDetails.name %></h2>
            <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">
            <p>Description: <%= organizationDetails.description %></p>
            <p>Contact: <a href="mailto:<%= organizationDetails.contact_email %>"><%= organizationDetails.contact_email %></a></p>
            <div class="mt-6">
                <a href="/edit-organization/<%= organizationDetails.organization_id %>" class="button button-edit">
                    <i data-lucide="edit-2" class="icon-sm"></i>
                    Edit Organization
                </a>
            </div>
        </section>

        <section class="organization-projects">
            <h3>Service Projects</h3>
            <% if (projects && projects.length > 0) { %>
                <ul>
                    <% projects.forEach(project => { %>
                        <li>
                            <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <p>No service projects found for this organization.</p>
            <% } %>
        </section>
    <% } %>
</main>

<%- include('partials/footer') %>
