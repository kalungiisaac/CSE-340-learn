<%- include('partials/header') %>

<main class="category-details-page">
    <nav class="breadcrumb">
        <a href="/categories">Categories</a>
        <i data-lucide="chevron-right" class="icon-sm"></i>
        <span><%= category.name %></span>
    </nav>

    <div class="mb-6">
        <a href="/categories" class="button button-outline">
            <i data-lucide="arrow-left" class="icon-sm"></i>
            Back to All Categories
        </a>
    </div>

    <div class="project-header">
        <h1><%= category.name %></h1>
        <div class="header-actions">
            <a href="/edit-category/<%= category.category_id %>" class="button button-edit">
                <i data-lucide="edit-2" class="icon-sm"></i>
                Edit Category
            </a>
        </div>
    </div>
    
    <p class="description-content"><%= category.description %></p>

    <div class="content-header mt-12">
        <h2>Projects in this Category</h2>
    </div>

    <% if (!projects || projects.length === 0) { %>
        <div class="empty-state">
            <i data-lucide="layers" class="icon-lg"></i>
            <p>No service projects found for this category at this time.</p>
        </div>
    <% } else { %>
        <div class="projects-container">
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <div class="project-header">
                        <% const dateObj = project.project_date ? new Date(project.project_date) : null; %>
                        <% if (dateObj) { %>
                            <div class="date-badge">
                                <span class="month"><%= dateObj.toLocaleDateString('en-US', { month: 'short' }) %></span>
                                <span class="day"><%= dateObj.getDate() %></span>
                            </div>
                        <% } %>
                        <div class="title-area">
                            <h3><a href="/project/<%= project.project_id %>"><%= project.title %></a></h3>
                        </div>
                    </div>

                    <div class="project-info">
                        <% if (project.description) { %>
                            <p class="description"><%= project.description.substring(0, 80) %><%= project.description.length > 80 ? '...' : '' %></p>
                        <% } %>

                        <% if (project.location) { %>
                            <div class="location">
                                <i data-lucide="map-pin" class="icon-sm"></i>
                                <span><%= project.location %></span>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="project-footer">
                        <a href="/project/<%= project.project_id %>" class="project-btn">
                            Details
                            <i data-lucide="arrow-right" class="icon-sm"></i>
                        </a>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
