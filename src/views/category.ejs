<%- include('partials/header') %>

<main class="category-details-page">
    <h1><%= category.name %></h1>
    <p><%= category.description %></p>

    <h2>Service Projects in this Category</h2>
    <% if (!projects || projects.length === 0) { %>
        <p>No service projects found for this category.</p>
    <% } else { %>
        <ul class="category-project-list">
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                </li>
            <% }); %>
        </ul>
    <% } %>
</main>

<%- include('partials/footer') %>
