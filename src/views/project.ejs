<%- include('partials/header') %>

<main class="project-details-page">
    <h1><%= title %></h1>

    <% if (!project) { %>
        <p>Project not found.</p>
    <% } else { %>
        <section class="project-summary">
            <h2><%= project.title %></h2>

            <% const formattedDate = project.date ? new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Date TBD'; %>
            <p><strong>Date:</strong> <%= formattedDate %></p>
            <p><strong>Location:</strong> <%= project.location %></p>

            <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>

            <h3>Description</h3>
            <p><%= project.description %></p>
            <% if (categories && categories.length > 0) { %>
                <div class="project-categories">
                    <strong>Categories:</strong>
                    <% categories.forEach(category => { %>
                        <a class="category-tag" href="/category/<%= category.category_id %>"><%= category.name %></a>
                    <% }); %>
                </div>
            <% } %>
        </section>
    <% } %>
</main>

<%- include('partials/footer') %>
