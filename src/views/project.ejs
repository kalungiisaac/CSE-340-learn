<%- include('partials/header') %>

<main class="project-details-page">
    <nav class="breadcrumb">
        <a href="/projects">Projects</a>
        <i data-lucide="chevron-right" class="icon-sm"></i>
        <span><%= project ? project.title : 'Details' %></span>
    </nav>

    <div class="mb-6">
        <a href="/projects" class="button button-outline">
            <i data-lucide="arrow-left" class="icon-sm"></i>
            Back to All Projects
        </a>
    </div>

    <% if (!project) { %>
        <div class="empty-state">
            <i data-lucide="search-x" class="icon-lg"></i>
            <p>Project not found.</p>
            <a href="/projects" class="button">Back to All Projects</a>
        </div>
    <% } else { %>
        <div class="project-grid">
            <div class="project-main">
                <header class="project-header">
                    <span class="status-badge">Active Opportunity</span>
                    <h1><%= project.title %></h1>
                    <div class="org-attribution">
                        <i data-lucide="building-2" class="icon-sm"></i>
                        Hosted by <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                    </div>
                </header>

                <section class="project-section">
                    <h3>About this Project</h3>
                    <div class="description-content">
                        <%= project.description %>
                    </div>
                </section>

                <% if (categories && categories.length > 0) { %>
                    <section class="project-section">
                        <h3>Categories</h3>
                        <div class="project-categories">
                            <% categories.forEach(category => { %>
                                <a class="category-tag" href="/category/<%= category.category_id %>">
                                    <i data-lucide="tag" class="icon-xs"></i>
                                    <%= category.name %>
                                </a>
                            <% }); %>
                        </div>
                    </section>
                <% } %>
            </div>

            <aside class="project-sidebar">
                <div class="sidebar-card">
                    <h4>Key Details</h4>
                    <div class="detail-item">
                        <i data-lucide="calendar" class="icon-blue"></i>
                        <div class="detail-text">
                            <span class="label">Project Date</span>
                            <span class="value"><%= project.date ? new Date(project.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : 'Date TBD' %></span>
                        </div>
                    </div>

                    <div class="detail-item">
                        <i data-lucide="map-pin" class="icon-blue"></i>
                        <div class="detail-text">
                            <span class="label">Location</span>
                            <span class="value"><%= project.location %></span>
                        </div>
                    </div>

                    <div class="project-actions">
                        <a href="/edit-project/<%= project.project_id %>" class="button button-edit button-full">
                            <i data-lucide="edit-2" class="icon-sm"></i>
                            Edit Project
                        </a>
                        <a href="/assign-categories/<%= project.project_id %>" class="button button-outline button-full">
                            <i data-lucide="settings" class="icon-sm"></i>
                            Manage Categories
                        </a>
                    </div>
                </div>
            </aside>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
