<%- include('partials/header') %>
<main class="form-page">
    <div class="form-container">
        <div class="form-header">
            <h1><%= title %></h1>
            <p>Create a new service opportunity for volunteers.</p>
        </div>

        <form action="/new-project" method="POST">
            <div class="form-group">
                <label for="title">Project Title</label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    placeholder="e.g. Annual Beach Cleanup"
                    maxlength="200"
                    required
                />
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    placeholder="Describe the project activities and requirements..."
                    maxlength="1000"
                    required
                ></textarea>
            </div>

            <div class="form-group">
                <label for="location">Location</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    placeholder="e.g. Riverside Park, Downtown"
                    maxlength="200"
                    required
                />
            </div>

            <div class="form-group">
                <label for="date">Project Date</label>
                <input
                    type="date"
                    id="date"
                    name="date"
                    required
                />
            </div>

            <div class="form-group">
                <label for="organizationId">Sponsoring Organization</label>
                <select
                    id="organizationId"
                    name="organizationId"
                    required
                >
                    <option value="">Select an organization</option>
                    <% organizations.forEach(org => { %>
                    <option value="<%= org.organization_id %>"><%= org.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn"><i data-lucide="plus-circle" class="icon-sm"></i> Create Service Project</button>
                <a href="/projects" class="cancel-link">Cancel and go back</a>
            </div>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
