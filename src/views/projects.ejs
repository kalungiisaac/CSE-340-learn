<%- include('partials/header') %>

<main class="projects-page">
    <!-- PROJECTS VIEW v2 -->
    <h1><%= title %></h1>

    <h2>Our Service Projects</h2>
    <p>Explore the next few upcoming service projects available through our network.</p>

    <% if (!projects || projects.length === 0) { %>
        <div class="project-card">
            <p>No upcoming service projects are available at this time.</p>
        </div>
    <% } else { %>
        <div class="projects-container">
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <h3><a href="/project/<%= project.project_id %>"><%= project.title %></a></h3>
                    <% const formattedDate = project.date ? new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Date TBD'; %>
                    <p><strong>Date:</strong> <%= formattedDate %></p>
                    <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
                    <% if (project.description) { %>
                        <p><%= project.description %></p>
                    <% } %>
                    <% if (project.location) { %>
                        <p><strong>Location:</strong> <%= project.location %></p>
                    <% } %>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
