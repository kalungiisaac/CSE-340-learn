<%- include('partials/header') %>
<main class="form-page">
    <div class="form-container">
        <div class="form-header">
            <h1><%= title %></h1>
            <p>Define a new category for service projects.</p>
        </div>

        <form action="/new-category" method="POST">
            <div class="form-group">
                <label for="name">Category Name</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="e.g. Environmental"
                    minlength="3"
                    maxlength="100"
                    required
                />
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea
                    id="description"
                    name="description"
                    placeholder="Briefly describe the focus of this category..."
                    maxlength="500"
                    required
                ></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn"><i data-lucide="plus-circle" class="icon-sm"></i> Create Category</button>
                <a href="/categories" class="cancel-link">Cancel and go back</a>
            </div>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
